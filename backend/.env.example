# URL de conexão com o PostgreSQL (Render fornece isso automaticamente
# se o banco for criado dentro do próprio Render; caso contrário, use a
# "External Database URL" do painel do Render)
DATABASE_URL="postgresql://usuario:senha@host:5432/monitor_custos?schema=public"

# Porta em que a API vai rodar (Render define PORT automaticamente em produção)
PORT=3333

# Origem(ns) permitida(s) para CORS — URL do frontend na Vercel
# Pode ser uma lista separada por vírgula
CORS_ORIGIN="http://localhost:5173,https://monitor-custos.vercel.app"

# Tamanho máximo aceito para upload do Excel (em MB)
MAX_UPLOAD_MB=80
